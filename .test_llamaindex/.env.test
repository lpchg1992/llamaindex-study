# =============================================
# 测试环境配置（LlamaIndex 升级测试专用）
# =============================================

# =============================================
# LLM 配置（使用硅基流动 SiliconFlow）
# =============================================
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# =============================================
# Embedding 配置（Ollama 多端点）
# =============================================
OLLAMA_EMBED_MODEL=bge-m3
EMBEDDING_DIM=1024
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LOCAL_URL=http://localhost:11434
OLLAMA_REMOTE_URL=

# =============================================
# 并行 Embedding 配置
# =============================================
MAX_RETRIES=3
RETRY_DELAY=1.0
OLLAMA_SHORT_TEXT_THRESHOLD=600
OLLAMA_FANOUT_TEXT_THRESHOLD=1800

# =============================================
# 存储路径配置 - 使用测试专用目录
# =============================================
OBSIDIAN_VAULT_ROOT=~/Documents/Obsidian Vault
ZOTERO_STORAGE_DIR=~/.llamaindex/storage/zotero
# 测试专用目录（不污染生产数据）
PERSIST_DIR=/Users/luopingcheng/Documents/GitHub/llamaindex-study/.test_llamaindex/storage

# =============================================
# 任务处理配置
# =============================================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
PROGRESS_UPDATE_INTERVAL=10
MAX_CONCURRENT_TASKS=10

# =============================================
# Reranker 配置
# =============================================
USE_RERANKER=false
RERANK_MODEL=Pro/BAAI/bge-reranker-v2-m3

# =============================================
# 向量数据库配置
# =============================================
VECTOR_STORE_TYPE=lancedb
VECTOR_DB_URI=
VECTOR_TABLE_NAME=llamaindex_test

# =============================================
# 数据目录配置
# =============================================
DATA_DIR=/Users/luopingcheng/Documents/GitHub/llamaindex-study/.test_llamaindex/data
