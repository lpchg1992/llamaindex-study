# =============================================
# LLM 配置（使用硅基流动 SiliconFlow）
# =============================================
# 硅基流动 API 地址（固定）
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# 你的硅基流动 API Key
SILICONFLOW_API_KEY=sk-xdispwicjwpiecbchvkfbbkqtwwvvyxarvxiapcosovaeamh
# 硅基流动上的模型名称（参考模型广场）
# 常用推荐：deepseek-ai/DeepSeek-V3、deepseek-ai/DeepSeek-R1、Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# =============================================
# Embedding 配置
# =============================================
# Ollama 供应商和模型通过 CLI/API 管理（参见 vendor add / model add）
# SiliconFlow API 地址（固定）
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# Embedding 模型
# 推荐 bge-m3（BAAI 出品，支持 100+ 语言，中文最强）
# 或 bge-large-zh-v1.5（专精中文）
OLLAMA_EMBED_MODEL=bge-m3
# 最大重试次数和延迟
MAX_RETRIES=5
RETRY_DELAY=2.0

# =============================================
# 索引配置
# =============================================
# 索引持久化目录
PERSIST_DIR=/Volumes/online/llamaindex

# Zotero 向量数据存储目录
ZOTERO_PERSIST_DIR=/Volumes/online/llamaindex/zotero
DATA_DIR=/Users/luopingcheng/Documents/GitHub/llamaindex-study/.llamaindex
# 检索返回的节点数量
TOP_K=20

# Reranker 配置
USE_RERANKER=true
RERANK_MODEL=Pro/BAAI/bge-reranker-v2-m3

# =============================================
# OCR 配置（PDF 扫描件识别）
