# =============================================
# LLM 配置（使用硅基流动 SiliconFlow）
# =============================================
# 硅基流动 API 地址（固定）
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# 你的硅基流动 API Key
SILICONFLOW_API_KEY=sk-xdispwicjwpiecbchvkfbbkqtwwvvyxarvxiapcosovaeamh
# 硅基流动上的模型名称（参考模型广场）
# 常用推荐：deepseek-ai/DeepSeek-V3、deepseek-ai/DeepSeek-R1、Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# =============================================
# Embedding 配置（本地 Ollama）
# =============================================
# Ollama 服务地址（本地运行）
OLLAMA_BASE_URL=http://localhost:11434
# Embedding 模型
# 推荐 bge-m3（BAAI 出品，支持 100+ 语言，中文最强）
# 或 bge-large-zh-v1.5（专精中文）
OLLAMA_EMBED_MODEL=bge-m3

# =============================================
# 索引配置
# =============================================
# 索引持久化目录
PERSIST_DIR=/volumes/online/llamaindex/storage
# 检索返回的节点数量
TOP_K=5

# =============================================
# Reranker 配置（可选）
# =============================================
# 是否启用 SiliconFlow 云端 reranker
USE_RERANKER=false
# SiliconFlow 上的 reranker 模型名称
RERANK_MODEL=Pro/BAAI/bge-reranker-v2-m3

# =============================================
# 向量数据库配置（可选）
# =============================================
# 向量数据库类型：lancedb（默认）、chroma、qdrant
VECTOR_STORE_TYPE=lancedb
# LanceDB/Chroma 的持久化目录（可选）
VECTOR_DB_URI=
# LanceDB 表名 / Chroma 集合名
VECTOR_TABLE_NAME=llamaindex

# Qdrant 专用配置（如使用 Qdrant）
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
