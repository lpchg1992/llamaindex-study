# =============================================
# LlamaIndex Study 配置说明
# =============================================
# 模型配置（供应商、API密钥、模型名称）全部通过 CLI 管理：
#   uv run llamaindex-study vendor add --help
#   uv run llamaindex-study model add --help
#
# 此文件保留与模型无关的全局设置（重试机制、功能开关、存储路径等）。
# 模型配置（如 embedding dimensions、batch_size）存储在数据库中，通过 WebUI 或 CLI 管理。

# =============================================
# 重试机制
# =============================================
# 用于 Ollama/其他 embedding 端点调用失败时的重试逻辑

MAX_RETRIES=5
# Embedding 端点调用最大重试次数
# 场景：当 Ollama 服务繁忙返回 503 或网络超时时会自动重试
# 适用：所有 embedding 请求（parallel_embedding.py）

RETRY_DELAY=2.0
# 重试间隔时间（秒），每次重试后会乘以退避系数
# 场景：配合 MAX_RETRIES 使用，控制重试频率
# 适用：所有 embedding 请求

OLLAMA_SHORT_TEXT_THRESHOLD=600
# 短文本优先单端点阈值（字符数）
# 场景：当文本长度小于此值时，优先使用单个端点处理（已废弃，仅保留兼容性）
# 适用：parallel_embedding.py 中的文本长度判断逻辑

OLLAMA_FANOUT_TEXT_THRESHOLD=1800
# 长文本阈值（已废弃，仅保留兼容性）
# 场景：历史遗留配置，不再影响实际行为

# =============================================
# 存储路径配置
# =============================================

OBSIDIAN_VAULT_ROOT=~/Documents/Obsidian Vault
# Obsidian Vault 根目录
# 场景：导入 Obsidian 笔记时以此目录为基准解析相对路径
# 适用：kb_core/registry.py - get_vault_root()

ZOTERO_STORAGE_DIR=~/.llamaindex/storage/zotero
# Zotero 附件存储目录（本地缓存）
# 场景：Zotero 文献的 PDF/附件下载后存储在此目录
# 适用：kb_zotero/ - ZoteroImporter

PERSIST_DIR=~/.llamaindex/storage
# LanceDB 向量数据库持久化目录
# 场景：所有知识库的向量数据存储位置
# 适用：rag/vector_store.py - LanceDBVectorStore

ZOTERO_PERSIST_DIR=~/.llamaindex/storage/zotero
# Zotero 专用向量数据目录
# 场景：Zotero 导入任务的向量数据存储位置
# 适用：task_executor.py - _execute_zotero()

DATA_DIR=./.llamaindex
# 运行时数据目录（进度文件、临时文件等）
# 场景：Zotero 导入进度文件、任务队列等运行时数据
# 适用：task_executor.py - 进度文件路径

# =============================================
# 任务处理配置
# =============================================

CHUNK_SIZE=512
# 文本分块大小（字符数）
# 场景：文档导入时，将长文本切分成不超过此大小的 chunks
# 适用：task_executor.py - Zotero 导入；rag/node_parser.py - SentenceSplitter
# 注意：hierarchical 分块策略使用 HIERARCHICAL_CHUNK_SIZES 而非此值

CHUNK_OVERLAP=50
# 文本分块重叠大小（字符数）
# 场景：相邻 chunks 之间的重叠字符数，保持上下文连贯性
# 适用：task_executor.py - Zotero 导入；rag/node_parser.py - SentenceSplitter

EMBED_BATCH_SIZE=32
# Embedding 批处理大小
# 场景：单次 API 调用发送的文本数量（仅影响调用频率，不影响结果）
# 适用：rag/config.py - embed_batch_size 配置

PROGRESS_UPDATE_INTERVAL=10
# 进度更新间隔（处理文件数）
# 场景：每处理 N 个文件后更新一次任务进度和心跳
# 适用：task_executor.py - _execute_obsidian(), _execute_zotero()
# 注意：影响 WebUI 进度条更新频率

MAX_CONCURRENT_TASKS=10
# 最大并发任务数
# 场景：系统同时处理的任务上限
# 适用：task_executor.py - 任务调度

HEARTBEAT_INTERVAL=30
# 任务心跳间隔（秒）
# 场景：长时间任务定期更新心跳，防止被标记为 stale
# 适用：task_executor.py - _update_heartbeat()

STALE_TASK_TIMEOUT=300
# 任务超时时间（秒）
# 场景：超过此时间未更新心跳的任务被判定为 stale，可能被清理
# 适用：task_executor.py - recover_stale_tasks()

# =============================================
# 检索配置
# =============================================

TOP_K=5
# 检索返回的 Top-K 结果数
# 场景：用户查询时返回最相关的 K 个 chunks
# 适用：rag/config.py - top_k；rag/query_engine.py - Retriever

USE_SEMANTIC_CHUNKING=false
# 启用语义分块（基于语义相似度切分文档）
# 场景：使用 SemanticChunker 替代固定大小分块，需要重建知识库才能生效
# 适用：rag/node_parser.py - 决定使用 SentenceSplitter 还是 SemanticChunker
# 注意：修改后需要重新导入文档

USE_AUTO_MERGING=false
# 启用 Auto-Merging Retriever（小块自动合并成大块）
# 场景：先用小 chunks 检索，再合并相关的小块成大的 context
# 适用：rag/retriever.py - AutoMergingRetriever
# 要求：知识库必须使用 hierarchical 分块策略

USE_HYBRID_SEARCH=false
# 启用混合搜索（向量检索 + BM25 关键词检索）
# 场景：结合语义相似度和关键词匹配，提供更全面的检索
# 适用：rag/retriever.py - BM25 + Vector 融合
# 注意：需要知识库支持 BM25（通常通过 LanceDB 实现）

HYBRID_SEARCH_MODE=relative_score
# 混合搜索融合模式
# 选项：relative_score（相对分数）、dynamic（动态）、converage（覆盖率）
# 场景：多路召回结果如何融合排序
# 适用：rag/retriever.py - 融合算法选择

HYBRID_SEARCH_ALPHA=0.5
# 混合搜索向量权重（0.0-1.0）
# 场景：1.0=仅向量检索，0.0=仅 BM25，0.5=两者平衡
# 适用：rag/retriever.py - 融合分数计算

# =============================================
# 分块策略配置
# =============================================

CHUNK_STRATEGY=hierarchical
# 分块策略
# 选项：hierarchical（层级分块）、sentence（句子分块）
# 场景：文档导入时的分块算法选择
# 适用：task_executor.py - vs.set_chunk_strategy()；rag/node_parser.py

HIERARCHICAL_CHUNK_SIZES=2048,1024,512
# 层级分块各层大小（逗号分隔，从大到小）
# 场景：三层分块 - L1(2048字符) -> L2(1024字符) -> L3(512字符)
# 适用：rag/node_parser.py - HierarchicalNodeParser
# 说明：检索时先用 L3 精确匹配，再逐步合并到 L2、L1 获取更大上下文

SENTENCE_CHUNK_SIZE=1024
# 句子分块模式的分块大小（字符数）
# 场景：USE_SEMANTIC_CHUNKING=false 且 CHUNK_STRATEGY=sentence 时使用
# 适用：rag/node_parser.py - SentenceSplitter

SENTENCE_CHUNK_OVERLAP=100
# 句子分块模式的重叠大小（字符数）
# 场景：相邻句子 chunks 之间的重叠
# 适用：rag/node_parser.py - SentenceSplitter

# =============================================
# Query Transform 配置
# =============================================
# 这些配置影响用户查询时的查询改写策略
# 可以任意组合同时启用，组合使用会获得更好的检索质量

USE_HYDE=false
# 启用 HyDE（Hypothetical Document Embeddings）
# 场景：先用 LLM 生成假设性回答，再用该回答去检索相关文档
# 适用：rag/query_transforms.py - HyDEQueryTransform
# 注意：需要 LLM 模型可用，会增加查询延迟

USE_QUERY_REWRITE=false
# 启用 Query Rewriting（查询重写）
# 场景：用 LLM 将用户查询改写为更优化的检索 query
# 适用：rag/query_transforms.py - QueryRewriterTransform

USE_MULTI_QUERY=false
# 启用多查询转换
# 场景：从多个角度生成 N 个变体 query，并行检索后融合结果
# 适用：rag/query_transforms.py - MultiQueryRetriever
# 注意：需要 LLM 模型可用

MULTI_QUERY_NUM=3
# 多查询转换生成的变体数量
# 场景：USE_MULTI_QUERY=true 时生效
# 适用：rag/query_transforms.py - MultiQueryRetriever

# =============================================
# Response Synthesizer 配置
# =============================================
# 答案生成模式，影响如何将检索到的 chunks 组装成最终回答

RESPONSE_MODE=compact
# 答案生成模式
# 选项：
#   - compact（默认）：压缩所有 chunks 后生成答案
#   - refine：迭代优化答案
#   - tree_summarize：层次化总结
#   - simple：简单拼接后生成
#   - accumulate：累加式生成
#   - no_text：仅返回源，不生成文本
# 场景：用户查询 Rag 结果时的答案组织方式
# 适用：rag/response_synthesizer.py - get_response_synthesizer()

# =============================================
# Reranker 配置
# =============================================

USE_RERANKER=false
# 启用重排序（Cross-Encoder Reranking）
# 场景：初步向量检索后，用 Cross-Encoder 模型对结果重新排序
# 适用：rag/retriever.py - Reranker
# 注意：需要配置 reranker 模型，会增加延迟但显著提升准确性

# =============================================
# 向量数据库配置
# =============================================

VECTOR_STORE_TYPE=lancedb
# 向量存储类型
# 选项：lancedb（默认）、qdrant
# 场景：选择底层向量数据库实现
# 适用：rag/vector_store.py - VectorStoreFactory

VECTOR_DB_URI=
# 向量数据库 URI（Qdrant 使用）
# 场景：Qdrant 模式下指定数据库连接地址
# 适用：rag/config.py - qdrant_url 配置
# 注意：LanceDB 使用 PERSIST_DIR 本地存储

VECTOR_TABLE_NAME=llamaindex
# 向量表名称
# 场景：LanceDB/Qdrant 中的表名
# 适用：rag/vector_store.py - LanceDBVectorStore

QDRANT_URL=http://localhost:6333
# Qdrant 数据库地址
# 场景：使用 Qdrant 作为向量存储时
# 适用：rag/config.py - qdrant_url

QDRANT_API_KEY=
# Qdrant API 密钥
# 场景：Qdrant 服务需要认证时
# 适用：rag/config.py - qdrant_api_key

# =============================================
# API 服务配置
# =============================================

API_PORT=37241
# API 服务端口
# 场景：FastAPI 服务监听端口
# 适用：api.py - uvicorn 启动参数
# 注意：WebUI 通过 VITE_API_PORT 环境变量连接此端口

# =============================================
# OCR 配置（PDF 扫描件识别）
# =============================================
# 当导入的 PDF 是扫描件（无文本层）时，自动调用 OCR 提取文字

# MinerU OCR（云端，推荐用于中文文档）
# 申请地址：https://www.mineru.cn/
MINERU_API_KEY=
# MinerU OCR 服务密钥
# 场景：PDF 是扫描件时自动调用 MinerU API 识别文字
# 适用：kb_processing/extractors.py - MinerUExtractor

MINERU_PIPELINE_ID=vlm
# MinerU OCR pipeline ID
# 场景：指定使用的 OCR 模型管道
# 适用：kb_processing/extractors.py - MinerUExtractor

# doc2x OCR（云端 MCP，适合英文文档）
# 申请地址：https://doc2x.noce.io/
DOC2X_API_KEY=
# doc2x OCR 服务密钥
# 场景：PDF 是扫描件时作为 MinerU 的替代方案
# 适用：kb_processing/extractors.py - Doc2xExtractor

# =============================================
# 模型配置（通过 CLI 管理，不要在此配置）
# =============================================
# 供应商、API密钥、模型名称、dimensions 等配置存储在数据库中
# 请运行以下命令配置：
#
# 添加供应商：
#   uv run llamaindex-study vendor add ollama --api-base=http://localhost:11434
#   uv run llamaindex-study vendor add siliconflow --api-base=https://api.siliconflow.cn/v1
#
# 添加模型：
#   uv run llamaindex-study model add ollama/bge-m3 --vendor ollama --type embedding
#   uv run llamaindex-study model add siliconflow/DeepSeek-V3 --vendor siliconflow --type llm
#
# 查看/修改模型配置（包含 dimensions 等参数）：
#   uv run llamaindex-study model list
#   uv run llamaindex-study model update siliconflow/bge-m3 --config '{"dimensions": 1024}'
