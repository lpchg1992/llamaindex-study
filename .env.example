# =============================================
# LLM 配置（使用硅基流动 SiliconFlow）
# =============================================
# 硅基流动 API 地址（固定）
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# 你的硅基流动 API Key（不要提交到仓库）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
# 硅基流动上的模型名称（参考模型广场）
# 常用推荐：Pro/deepseek-ai/DeepSeek-V3.2、deepseek-ai/DeepSeek-R1、Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# =============================================
# Embedding 配置（Ollama 多端点）
# =============================================
# Ollama Embedding 模型名称
OLLAMA_EMBED_MODEL=bge-m3
# Embedding 向量维度（bge-m3 为 1024）
EMBEDDING_DIM=1024
# 默认单端点地址（未设置 OLLAMA_LOCAL_URL 时回退到这里）
OLLAMA_BASE_URL=http://localhost:11434
# 本地 Ollama 服务地址
OLLAMA_LOCAL_URL=http://localhost:11434
# 远程 Ollama 服务地址（留空表示禁用第二端点）
OLLAMA_REMOTE_URL=

# =============================================
# 并行 Embedding 配置
# =============================================
# 每个端点最大重试次数
MAX_RETRIES=3
# 重试延迟（秒）
RETRY_DELAY=1.0
# 短文本优先单端点调度阈值（字符数）
OLLAMA_SHORT_TEXT_THRESHOLD=600
# 长文本触发双端点竞速阈值（字符数）
OLLAMA_FANOUT_TEXT_THRESHOLD=1800

# =============================================
# 存储路径配置
# =============================================
# Obsidian Vault 根目录
OBSIDIAN_VAULT_ROOT=~/Documents/Obsidian Vault
# Obsidian 向量数据存储目录（已废弃，请使用 PERSIST_DIR）
# OBSIDIAN_STORAGE_DIR=~/.llamaindex/storage
# Zotero 向量数据存储目录
ZOTERO_STORAGE_DIR=~/.llamaindex/storage/zotero
# 通用存储目录（备用）
PERSIST_DIR=~/.llamaindex/storage

# =============================================
# 任务处理配置
# =============================================
# 文本分块大小
CHUNK_SIZE=512
# 文本分块重叠大小
CHUNK_OVERLAP=50
# Embedding 批处理大小
EMBED_BATCH_SIZE=32
# 进度更新间隔（处理多少文件更新一次）
PROGRESS_UPDATE_INTERVAL=10
# 最大并发任务数
MAX_CONCURRENT_TASKS=10

# =============================================
# 检索配置
# =============================================
# 默认 top_k（每个知识库返回的结果数量）
TOP_K=5
# 是否启用语义分块（需要 llama-index-packs-node-parser-semantic-chunking）
USE_SEMANTIC_CHUNKING=false
# 是否启用 Auto-Merging Retriever（需要配合 HierarchicalNodeParser 构建的知识库）
USE_AUTO_MERGING=false
# 是否启用混合搜索（向量 + BM25）
USE_HYBRID_SEARCH=false
# 混合搜索融合模式：relative_score（推荐）, RRF, dist_based_score
HYBRID_SEARCH_MODE=relative_score
# 混合搜索权重（用于 dist_based_score 模式，0.0-1.0，0.5 表示平衡）
HYBRID_SEARCH_ALPHA=0.5

# =============================================
# Reranker 配置（可选）
# =============================================
# 是否启用 SiliconFlow 云端 reranker
USE_RERANKER=false
# SiliconFlow 上的 reranker 模型名称
RERANK_MODEL=Pro/BAAI/bge-reranker-v2-m3

# =============================================
# 向量数据库配置（可选）
# =============================================
# 向量数据库类型：lancedb（默认）、chroma、qdrant
VECTOR_STORE_TYPE=lancedb
# LanceDB/Chroma 的持久化目录（可选）
VECTOR_DB_URI=
# LanceDB 表名 / Chroma 集合名
VECTOR_TABLE_NAME=llamaindex

# Qdrant 专用配置（如使用 Qdrant）
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================
# API 服务配置
# =============================================
# API 服务端口（默认 37241）
API_PORT=37241

# =============================================
# 数据目录配置
# =============================================
# SQLite 数据库目录
DATA_DIR=./.llamaindex
